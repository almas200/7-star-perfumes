rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function: check if user is an authorized admin
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'almasmansuri2004@gmail.com' ||
        request.auth.token.email == 'kavialmas@gmail.com' ||
        (get(/databases/$(database)/documents/settings/admins).exists() &&
         request.auth.token.email in get(/databases/$(database)/documents/settings/admins).data.emails)
      );
    }
    
    // Products: public read, admin write
    match /products/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Brands: public read, admin write
    match /brands/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Settings: public read, admin write
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
