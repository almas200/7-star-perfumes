rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Allow public read for product images
      allow read: if true;
      // Allow write only for authenticated admin with specific emails
      allow write: if request.auth != null && (
        request.auth.token.email == 'kavialmas@gmail.com' ||
        request.auth.token.email == 'almasmansuri2004@gmail.com'
      );
    }
  }
}
